# ============================================
# 抖音直播监控系统 - Docker 环境变量配置
# ============================================
# 复制此文件为 .env 并修改相应的值
# cp .env.docker.example .env

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=root123456
DB_USER=douyin
DB_PASSWORD=douyin123456
DB_NAME=douyin_live
DB_PORT=3306

# ============================================
# 后端服务配置
# ============================================
PORT=5678
LOG_LEVEL=info

# ============================================
# 抖音配置
# ============================================
# 从浏览器获取 Cookie（必填）
DOUYIN_COOKIE=

# ============================================
# 开播监听配置
# ============================================
MONITOR_CHECK_INTERVAL=60000
MONITOR_RESTART_COOLDOWN=300000

# ============================================
# QQ 机器人配置（可选）
# ============================================
QQ_BOT_APP_ID=
QQ_BOT_APP_SECRET=
QQ_BOT_USER_ID=

# ============================================
# Server酱配置（可选）
# ============================================
SERVERCHAN_SENDKEY=

# ============================================
# 飞书机器人配置（可选）
# ============================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
