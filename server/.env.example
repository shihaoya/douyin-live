# 服务器配置
PORT=5678

# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=douyin_live
DB_PORT=3306

# 抖音配置
DOUYIN_COOKIE=

# 日志配置
LOG_LEVEL=info
LOG_DIR=logs

# 开播监听配置
MONITOR_CHECK_INTERVAL=60000        # 检查间隔（毫秒），默认60秒
MONITOR_RESTART_COOLDOWN=300000      # 重启冷却时间（毫秒），默认5分钟

# QQ机器人配置（可选）
QQ_BOT_APP_ID=                       # QQ开放平台AppID
QQ_BOT_APP_SECRET=                   # QQ开放平台AppSecret
QQ_BOT_USER_ID=                      # 用户OpenID（可通过刷新按钮自动获取）
